{
  "name": "@rafabd1/proteus",
  "version": "0.1.2",
  "description": "Structured, continuous vulnerability research runtime and Codex plugin.",
  "type": "commonjs",
  "bin": {
    "proteus": "./dist/cli.js",
    "proteus-mcp": "./dist/mcp.js"
  },
  "files": [
    "dist",
    "plugins",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build",
    "start": "node dist/cli.js",
    "smoke": "npm run build && node scripts/smoke-test.mjs && node scripts/mcp-smoke-test.mjs",
    "test": "npm run check && npm run smoke"
  },
  "keywords": [
    "security-research",
    "vulnerability-research",
    "bug-bounty",
    "offensive-security",
    "codex-plugin"
  ],
  "license": "GPL-3.0-or-later",
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^24.10.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
